memory.assigned_spawn_store_request := parse("action={action} path={path} value={value}", memory.assigned_spawn_store_request_input)
send(memory.assigned_spawn_store_delegate_id, memory.assigned_spawn_store_request)
memory.assigned_send := parse("memory.{path} := send(memory.echo_id, {value})", message.text)
