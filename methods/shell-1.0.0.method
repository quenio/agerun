send(memory.assignment_store_delegate_id, memory.assignment_store_request)
memory.matched_forms := memory.is_assigned_spawn + memory.is_assigned_send + memory.is_plain_spawn + memory.is_plain_send_prompt + memory.is_assignment
memory.last_error := if(memory.matched_forms, "", "Invalid shell syntax")
