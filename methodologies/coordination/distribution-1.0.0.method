memory.is_distribute := if(message.action = "distribute", 1, 0)
memory.is_route_result := if(message.action = "route_result", 1, 0)
memory.routing_agent := if(memory.is_distribute = 1, message.routing_agent, memory.routing_agent)
memory.reply_to := if(memory.is_distribute = 1, message.reply_to, memory.reply_to)
memory.work_id := if(memory.is_distribute = 1, message.work_id, memory.work_id)
memory.work_text := if(memory.is_distribute = 1, message.work_text, memory.work_text)
memory.completed := if(memory.is_distribute = 1, 0, memory.completed)
memory.route_message := {
  action: "route"
  mode: "many"
  targets: message.workers
  payload_action: "work"
  payload_text: memory.work_text
  correlation_id: memory.work_id
  reply_to: memory.self
  routed_count: 0
  sent_count: 0
}
memory.route_send_result := send(memory.routing_agent * memory.is_distribute, memory.route_message)
memory.route_sent := if(memory.is_distribute = 1, memory.route_send_result, memory.route_sent)
memory.route_result_matches := if(message.correlation_id = memory.work_id, 1, 0)
memory.not_completed := if(memory.completed = 0, 1, 0)
memory.valid_route_result := memory.is_route_result * memory.route_sent * memory.route_result_matches
memory.valid_route_result := memory.valid_route_result * memory.not_completed
memory.status := if(memory.valid_route_result = 1, "distributed", memory.status)
memory.status := if(memory.is_distribute = 1, "routing", memory.status)
memory.route_failed := if(memory.route_sent = 0, 1, 0)
memory.route_failed := memory.route_failed * memory.is_distribute
memory.status := if(memory.route_failed = 1, "route_failed", memory.status)
memory.assignment_count := if(memory.valid_route_result = 1, message.routed_count, 0)
memory.sent_count := if(memory.valid_route_result = 1, message.sent_count, memory.route_sent)
memory.route_status := if(memory.valid_route_result = 1, message.status, memory.status)
memory.report_message := {
  action: "distribution_result"
  status: memory.status
  work_id: memory.work_id
  assignment_count: memory.assignment_count
  sent_count: memory.sent_count
  route_status: memory.route_status
  route_sent: memory.route_sent
}
memory.should_report := memory.valid_route_result + memory.route_failed
memory.report_target := memory.reply_to * memory.should_report
memory.report_sent := send(memory.report_target, memory.report_message)
memory.completed := if(memory.report_sent = 1, 1, memory.completed)
