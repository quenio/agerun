memory.is_start := if(message.action = "start", 1, 0)
memory.is_message := if(message.action = "message", 1, 0)
memory.is_summary := if(message.action = "summary", 1, 0)
memory.is_close := if(message.action = "close", 1, 0)
memory.conversation_id := if(memory.is_start = 1, message.conversation_id, memory.conversation_id)
memory.user_id := if(memory.is_start = 1, message.user_id, memory.user_id)
memory.reply_to := if(memory.is_start = 1, message.reply_to, memory.reply_to)
memory.state := if(memory.is_start = 1, "active", memory.state)
memory.turn_count := if(memory.is_start = 1, 0, memory.turn_count)
memory.previous_text := if(memory.is_start = 1, "", memory.previous_text)
memory.last_text := if(memory.is_start = 1, "", memory.last_text)
memory.last_intent := if(memory.is_start = 1, "", memory.last_intent)
memory.previous_text := if(memory.is_message = 1, memory.last_text, memory.previous_text)
memory.last_text := if(memory.is_message = 1, message.text, memory.last_text)
memory.last_intent := if(memory.is_message = 1, message.intent, memory.last_intent)
memory.turn_count := if(memory.is_message = 1, memory.turn_count + 1, memory.turn_count)
memory.state := if(memory.is_close = 1, "closed", memory.state)
memory.summary_text := build("conversation={conversation_id}|user={user_id}|state={state}|turns={turn_count}|last={last_text}|previous={previous_text}", memory)
memory.response_action := if(memory.is_summary = 1, "conversation_summary", "conversation_status")
memory.response_action := if(memory.is_close = 1, "conversation_closed", memory.response_action)
memory.response_text := if(memory.is_summary = 1, memory.summary_text, memory.state)
memory.response_text := if(memory.is_message = 1, memory.summary_text, memory.response_text)
memory.response_message := {
  action: memory.response_action
  conversation_id: memory.conversation_id
  state: memory.state
  text: memory.response_text
  turn_count: memory.turn_count
}
memory.response_sent := send(memory.reply_to, memory.response_message)
