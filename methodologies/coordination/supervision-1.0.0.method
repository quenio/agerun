memory.lifecycle_has_remaining := if(memory.lifecycle_remaining_count > 0, 1, 0)
memory.lifecycle_continue_needed := memory.is_validate_lifecycle * memory.lifecycle_has_remaining
memory.lifecycle_continue_message := {
  action: "validate_lifecycle"
  type: "request"
  trace_id: message.trace_id
  lifecycle_action: message.lifecycle_action
  child_agent_id: message.child_agent_id
  child_method_name: message.child_method_name
  child_method_version: message.child_method_version
  remaining_child_agent_ids: memory.remaining_lifecycle_child_agent_ids
