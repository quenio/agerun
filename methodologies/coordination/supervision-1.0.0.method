  lifecycle_tracked: memory.lifecycle_tracked
  lifecycle_handled: memory.lifecycle_handled
}
memory.lifecycle_continue_sent := send(memory.self * memory.lifecycle_continue_needed, memory.lifecycle_continue_message)
memory.lifecycle_continue_failed := if(memory.lifecycle_continue_sent = 0, 1, 0)
memory.lifecycle_continue_failed := memory.lifecycle_continue_failed * memory.lifecycle_continue_needed
memory.lifecycle_no_remaining := 1 - memory.lifecycle_has_remaining
memory.lifecycle_scan_exhausted := memory.is_validate_lifecycle * memory.lifecycle_no_remaining
memory.lifecycle_not_matched := 1 - memory.lifecycle_tracked
memory.lifecycle_untracked := memory.lifecycle_scan_exhausted * memory.lifecycle_not_matched
memory.lifecycle_duplicate := memory.lifecycle_scan_exhausted * memory.lifecycle_tracked
memory.lifecycle_duplicate := memory.lifecycle_duplicate * memory.lifecycle_handled
memory.lifecycle_not_already_handled := 1 - memory.lifecycle_handled
memory.tracked_failure_event := memory.lifecycle_scan_exhausted * memory.lifecycle_tracked
memory.tracked_failure_event := memory.tracked_failure_event * memory.lifecycle_not_already_handled
