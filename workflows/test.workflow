workflow_name=test_workflow workflow_version=1.0.0 initial_stage=intake terminal_completed=completed terminal_rejected=rejected requires_local_completion=1 item_fields=item_id|title|priority|owner|review_status stages=intake|triage|active|review|completion transition_count=4 transition_1_from=intake transition_1_to=triage transition_1_prompt=intake_to_triage_prompt Evaluate test intake for item {item_id}. Return outcome={outcome} as advance, stay, or reject and reason={reason}. transition_2_from=triage transition_2_to=active transition_2_prompt=triage_to_active_prompt Evaluate test triage for item {item_id}. Return outcome={outcome} as advance, stay, or reject and reason={reason}. transition_3_from=active transition_3_to=review transition_3_prompt=active_to_review_prompt Evaluate test active work for item {item_id}. Return outcome={outcome} as advance, stay, or reject and reason={reason}. transition_4_from=review transition_4_to=completion transition_4_prompt=review_to_completion_prompt Evaluate test review with review_status={review_status}. Return outcome={outcome} as advance, stay, or reject and reason={reason}.
